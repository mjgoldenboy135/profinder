
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users:
    // - Anyone can create a user profile (e.g., on signup), if authenticated.
    // - Anyone can read any user's profile (for public profiles).
    // - Only the user themselves can update their own profile.
    match /users/{userId} {
      allow create: if request.auth != null;
      allow read: if true; // Allows public reads of user profiles
      allow update: if request.auth != null && request.auth.uid == userId;
      // allow delete: if false; // Example: no one can delete for now
    }

    // Chats:
    // - Authenticated users can create chats.
    // - Users can only get (read single) chats they are a participant in.
    // - Authenticated users can list chats (client must filter by participantIds).
    // - Users can only update or delete chats they are a participant in.
    match /chats/{chatId} {
      allow create: if request.auth != null;
      allow get: if request.auth != null && request.auth.uid in resource.data.participantIds;
      // For listing chats by a user, the client-side query must include
      // `where('participantIds', 'array-contains', request.auth.uid)`.
      // This rule allows any authenticated user to *attempt* a list operation,
      // relying on client-side queries to enforce actual participation.
      allow list: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid in resource.data.participantIds;

      // Messages subcollection within a chat:
      // - Users can create (send) messages in chats they are part of.
      // - Users can read messages in chats they are part of.
      match /messages/{messageId} {
        // Check if the user is a participant in the parent chat document
        allow create: if request.auth != null && get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds.hasAny([request.auth.uid]);
        allow read: if request.auth != null && get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds.hasAny([request.auth.uid]);
        // allow update, delete: if request.auth != null && request.resource.data.senderId == request.auth.uid; // Example rule
      }
    }
  }
}
