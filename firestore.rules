
rules_version = '2';

service cloud.firestore {
  // Specifically target your 'profind' database
  match /databases/profind/documents {

    // Users can read anyone's profile, as they are public by design in this app.
    // They can only create their own profile (document ID must match their UID).
    // They can only update their own profile.
    // Deletion of profiles is disallowed for safety.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false; 
    }

    // A user can read a chat if they are one of the participants.
    // A user can create a chat if they are one of the participants.
    // A user can update a chat (e.g., last message) if they are a participant.
    // A user can delete a chat if they are a participant.
    match /chats/{chatId} {
      allow read, update, delete: if request.auth != null && request.auth.uid in resource.data.participantIds;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participantIds;
      
      // Messages can be read by anyone in the chat.
      // A user can only create messages as themselves (senderId must match their UID).
      // Updating/deleting messages is disallowed for simplicity and record-keeping.
      match /messages/{messageId} {
        allow read: if get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds.hasAny([request.auth.uid]);
        allow create: if request.auth != null && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }
  }
}
