rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection
    match /users/{userId} {
      // Anyone can read user profiles (e.g., for viewing public profiles)
      // Adjust to `if request.auth != null;` if only logged-in users can see profiles.
      allow read: if true; 

      // Only the authenticated user themselves can create or update their own profile.
      allow create, update: if request.auth != null && request.auth.uid == userId;
      
      // Users should not delete their own profiles directly unless through a specific feature.
      allow delete: if false; 
    }

    // Chats collection
    match /chats/{chatId} {
      // Allow read if the authenticated user is one of the participants in the chat.
      allow read: if request.auth != null && request.auth.uid in resource.data.participantIds;

      // Allow create if the authenticated user is one of the participants in the new chat document.
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participantIds;

      // Allow update (e.g., for lastMessageTimestamp) if the authenticated user is a participant.
      // Ensure participantIds cannot be changed after creation by an update operation.
      allow update: if request.auth != null && request.auth.uid in resource.data.participantIds
                       && request.resource.data.participantIds == resource.data.participantIds;
      
      // Disallow direct deletion of chats for now. Implement as a specific feature if needed.
      allow delete: if false;

      // Messages subcollection within each chat
      match /messages/{messageId} {
        // Allow read if the authenticated user is a participant in the parent chat.
        // Uses a get() call to check the parent chat document.
        allow read: if request.auth != null && get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds.hasAny([request.auth.uid]);

        // Allow create (send message) if the authenticated user is a participant in the parent chat
        // and the senderId in the new message matches the authenticated user's UID.
        allow create: if request.auth != null && get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds.hasAny([request.auth.uid])
                         && request.resource.data.senderId == request.auth.uid;
        
        // Messages are generally immutable once sent.
        allow update: if false;
        allow delete: if false;
      }
    }
  }
}
