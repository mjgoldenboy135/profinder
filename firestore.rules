rules_version = '2';

// The 'profind' database
service cloud.firestore {
  match /databases/profind/documents {

    // Rules for the 'users' collection
    match /users/{userId} {
      // ANYONE can read a user's public profile data.
      // This is necessary for the user list, map, and public profile pages to work.
      allow read: if true;

      // A user can ONLY CREATE their OWN profile document.
      // The `request.auth.uid` must match the document's ID (`userId`).
      allow create: if request.auth != null && request.auth.uid == userId;

      // A user can ONLY UPDATE their OWN profile document.
      allow update: if request.auth != null && request.auth.uid == userId;

      // Deleting user documents is not allowed from the client-side.
      allow delete: if false;
    }

    // Rules for the 'chats' collection
    match /chats/{chatId} {
      // Allow read/get if the user is a participant in the chat.
      // This is essential for opening a chat and listing existing chats.
      allow get, list: if request.auth != null && request.auth.uid in resource.data.participantIds;

      // A logged-in user can create a new chat.
      // Additional security: ensure the creator is one of the participants.
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participantIds;

      // Only a participant can update a chat (e.g., to change the last message).
      allow update: if request.auth != null && request.auth.uid in resource.data.participantIds;

      // Allow a participant to delete a chat.
      allow delete: if request.auth != null && request.auth.uid in resource.data.participantIds;

      // Rules for the 'messages' subcollection within a chat
      match /messages/{messageId} {
        // Allow read/list of messages if the user is a participant of the parent chat document.
        allow get, list: if request.auth != null && get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds.hasAny([request.auth.uid]);

        // Allow a user to create a message if they are a participant in the chat
        // AND the message they are creating is from themselves.
        allow create: if request.auth != null && get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds.hasAny([request.auth.uid]) && request.resource.data.senderId == request.auth.uid;
        
        // Messages cannot be updated or deleted from the client-side.
        allow update, delete: if false;
      }
    }
  }
}