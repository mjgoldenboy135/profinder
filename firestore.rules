
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny all access unless explicitly allowed
    match /{document=**} {
      allow read, write: if false;
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      // Any authenticated user can read public user profiles
      allow read: if request.auth != null;

      // Only the authenticated user can create their own profile
      allow create: if request.auth != null && request.auth.uid == userId;

      // Only the authenticated user can update their own profile
      allow update: if request.auth != null && request.auth.uid == userId;

      // Users should not be able to delete their profiles through the app
      allow delete: if false;
    }

    // Rules for the 'chats' collection and its 'messages' subcollection
    match /chats/{chatId} {
      // A user can read, update, or delete a chat if they are a participant
      allow read, update, delete: if request.auth != null && request.auth.uid in resource.data.participantIds;
      
      // A user can create a chat if they are one of the participants
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participantIds;
      
      // Rules for the 'messages' subcollection within a chat
      match /messages/{messageId} {
        // A user can read messages in a chat they are a participant of
        allow read: if get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds.hasAny([request.auth.uid]);
        
        // A user can create (send) a message if they are a participant in the chat
        allow create: if get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds.hasAny([request.auth.uid]);

        // Messages cannot be updated or deleted by users
        allow update, delete: if false;
      }
    }
  }
}
