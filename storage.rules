rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Profile Pictures:
    // - Allow anyone to read (profile pictures are public).
    // - Allow authenticated users to write (upload, update, delete) to their own profile picture path.
    match /profilePictures/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // By default, if no other rules match, access is denied.
    // So, all other paths not covered by the rule above will be inaccessible.
  }
}
