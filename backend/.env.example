SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# SQLite by default; on Render this is set to the Postgres connection string.
DATABASE_URL=sqlite:///db.sqlite3
# Origins allowed to call the REST API (CORS). Comma-separated.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:9002
# Optional: extra origins allowed to open the chat WebSocket. Falls back to
# CORS_ALLOWED_ORIGINS when empty.
WS_ALLOWED_ORIGINS=
# Optional: trusted origins for CSRF (set your frontend HTTPS origin in prod).
CSRF_TRUSTED_ORIGINS=
MEDIA_ROOT=media
