
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users Collection
    // - Anyone can create a user profile (e.g., during sign-up).
    // - Only the authenticated owner of a profile can read, update, or delete their own profile.
    // - Other authenticated users can read profiles (e.g., for user lists, public profiles).
    match /users/{userId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null; // Allows authenticated users to read any profile
      allow update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Chats Collection
    // - Authenticated users can create new chats.
    // - Only participants of a chat can read or update it.
    // - Only participants of a chat can delete it.
    match /chats/{chatId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null && request.auth.uid in resource.data.participantIds;
      allow delete: if request.auth != null && request.auth.uid in resource.data.participantIds;

      // Messages Subcollection (within a chat)
      // - Only participants of the parent chat can create (send) messages.
      // - Only participants of the parent chat can read messages.
      // - Generally, messages are not updated or deleted by users directly, but if needed:
      //   allow update, delete: if request.auth != null && request.auth.uid == resource.data.senderId; // Example: only sender can edit/delete
      match /messages/{messageId} {
        allow create: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds;
        allow read: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds;
        // For simplicity, disallow update/delete of individual messages by users for now.
        // If needed, uncomment and refine the rule below.
        allow update, delete: if false;
        // Example: allow update, delete: if request.auth != null && request.auth.uid == resource.data.senderId;
      }
    }
  }
}
