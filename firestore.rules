rules_version = '2';

// Specify the database to apply the rules to
service cloud.firestore {
  match /databases/profind/documents {

    // Rules for the 'users' collection
    match /users/{userId} {
      // Allow anyone to create their own user document
      // This is necessary for the initial sign-up process.
      // The request.auth.uid must match the document's userId.
      allow create: if request.auth != null && request.auth.uid == userId;

      // Allow any authenticated user to read any other user's profile.
      // This is for public profile viewing.
      allow read: if request.auth != null;

      // Allow a user to update their own document.
      // This is for editing their own profile.
      allow update: if request.auth != null && request.auth.uid == userId;

      // Generally, deleting users should be handled by a server-side process or admin role.
      // For this app, we disallow client-side deletion of user profiles.
      allow delete: if false;
    }

    // Rules for the 'chats' collection and its 'messages' subcollection
    match /chats/{chatId} {
      // A user can read or write to a chat document only if their UID is in the participantIds array.
      allow read, write, delete: if request.auth != null && request.auth.uid in resource.data.participantIds;

      // Rules for the 'messages' subcollection within a chat
      match /messages/{messageId} {
        // A user can read messages in a chat if they are a participant of that chat.
        // We use get() to check the parent chat document's participantIds.
        allow read: if request.auth != null && get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds.hasAny([request.auth.uid]);
        
        // A user can create a message if they are a participant in the chat
        // and the message they are creating is from them.
        allow create: if request.auth != null && get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds.hasAny([request.auth.uid]) && request.resource.data.senderId == request.auth.uid;
        
        // Users cannot update or delete individual messages.
        allow update, delete: if false;
      }
    }
  }
}
