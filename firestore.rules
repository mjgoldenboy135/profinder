
rules_version = '2';

// These rules are for the 'profind' database
service cloud.firestore {
  match /databases/profind/documents {

    // Rules for the 'users' collection
    match /users/{userId} {
      // Any authenticated user can view other user profiles.
      allow read: if request.auth != null;

      // A user can create their own profile document.
      // A user can update their own profile document.
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Rules for the 'chats' collection and their 'messages' subcollection
    match /chats/{chatId} {
      // A user can read or delete a chat document ONLY if their UID is in the participantIds array.
      allow read, delete: if request.auth != null && request.auth.uid in resource.data.participantIds;

      // A user can create a chat if their UID is in the new chat's participantIds array.
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participantIds;

      // A user can update a chat (e.g., last message) if they are a participant.
      allow update: if request.auth != null && request.auth.uid in resource.data.participantIds;

      // Rules for the 'messages' subcollection within a chat
      match /messages/{messageId} {
        // A user can read messages in a chat if they are a participant of that chat.
        allow read: if request.auth != null && get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds.hasAny([request.auth.uid]);

        // A user can create (send) a message in a chat if they are a participant.
        allow create: if request.auth != null && get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds.hasAny([request.auth.uid]);
        
        // A user can delete their own message.
        allow delete: if request.auth != null && resource.data.senderId == request.auth.uid;
      }
    }
  }
}
