
rules_version = '2';

service cloud.firestore {
  // Specify the database name explicitly.
  match /databases/profind/documents {
    
    // =====================================================================
    //   User Profiles (`users`)
    // =====================================================================
    match /users/{userId} {
      
      // --- READ ---
      // Anyone who is logged in can read anyone else's profile.
      // This is necessary for the user list, map view, and public profile pages.
      allow read: if request.auth != null;

      // --- CREATE ---
      // A user can only create their OWN profile document.
      // This is the critical rule for fixing the sign-up/login flow.
      allow create: if request.auth != null && request.auth.uid == userId;

      // --- UPDATE ---
      // A user can only update their OWN profile document.
      // They cannot change their ID, email, or creation date.
      allow update: if request.auth != null && request.auth.uid == userId
                    && request.resource.data.id == resource.data.id
                    && request.resource.data.email == resource.data.email
                    && request.resource.data.createdAt == resource.data.createdAt;
                    
      // --- DELETE ---
      // Deleting user documents is not allowed from the client for data integrity.
      allow delete: if false;
    }

    // =====================================================================
    //   Chats (`chats`) and Messages (`chats/{chatId}/messages`)
    // =====================================================================
    match /chats/{chatId} {
      
      // Helper function to check if the requesting user is a participant in the chat.
      function isParticipant() {
        return request.auth != null && request.auth.uid in resource.data.participantIds;
      }
      
      // --- READ ---
      // Only participants of the chat can read the chat document (and its messages).
      allow get, list: if isParticipant();

      // --- CREATE ---
      // An authenticated user can create a chat, as long as they are one of the participants.
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participantIds;

      // --- UPDATE ---
      // Only a participant can update a chat document (e.g., to update the last message).
      allow update: if isParticipant();
      
      // --- DELETE ---
      // Only a participant can delete a chat document.
      allow delete: if isParticipant();

      // --- Messages Subcollection ---
      match /messages/{messageId} {
        // Inherit the read rule: only participants can read messages.
        allow read: if isParticipant();
        
        // A participant can create a message.
        allow create: if isParticipant();
        
        // No one can update or delete individual messages from the client.
        allow update, delete: if false;
      }
    }
  }
}
