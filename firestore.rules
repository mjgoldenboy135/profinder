
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection
    match /users/{userId} {
      // Anyone can read user profiles (e.g., for viewing public profiles)
      // Adjust to `if request.auth != null;` if only logged-in users can see profiles.
      allow read: if true; 

      // Only the authenticated user themselves can create or update their own profile.
      // This is crucial for sign-up and profile editing.
      allow create, update: if request.auth != null && request.auth.uid == userId;
      
      // Generally, users should not be able to delete their own (or other's) profiles directly
      // unless you have a specific "delete account" feature that handles this carefully.
      allow delete: if false; 
    }

    // Chats collection
    match /chats/{chatId} {
      // Allow read if the authenticated user's UID is in the participantIds array of the chat document.
      allow read: if request.auth != null && request.auth.uid in resource.data.participantIds;

      // Allow create if the authenticated user's UID is in the participantIds array of the new document.
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participantIds;

      // Allow update (e.g., for lastMessage, updatedAt) if the authenticated user's UID is in the participantIds array.
      // Be mindful of what fields can be updated. For example, participantIds should generally not be updatable after creation
      // without specific logic.
      allow update: if request.auth != null && request.auth.uid in resource.data.participantIds;
      
      // Disallow delete unless you have specific admin or user-driven features for it.
      allow delete: if false;

      // Messages subcollection within each chat
      match /messages/{messageId} {
        // Allow read of messages if the user is a participant in the parent chat.
        allow read: if request.auth != null && get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds.hasAny([request.auth.uid]);

        // Allow create (sending) of messages if the user is a participant in the parent chat
        // and the senderId in the new message matches the authenticated user's UID.
        allow create: if request.auth != null && get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds.hasAny([request.auth.uid])
                        && request.resource.data.senderId == request.auth.uid;
        
        // Messages are generally immutable.
        allow update, delete: if false;
      }
    }
    // Add rules for any other collections you might create in the 'profind' database here.
  }
}
