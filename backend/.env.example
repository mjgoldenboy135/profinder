SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# SQLite by default; on Render this is set to the Postgres connection string.
DATABASE_URL=sqlite:///db.sqlite3
# Origins allowed to call the REST API (CORS). Comma-separated.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:9002
# Optional: extra origins allowed to open the chat WebSocket. Falls back to
# CORS_ALLOWED_ORIGINS when empty.
WS_ALLOWED_ORIGINS=
# Optional: trusted origins for CSRF (set your frontend HTTPS origin in prod).
CSRF_TRUSTED_ORIGINS=
MEDIA_ROOT=media
# Public URL of the frontend (used in password-reset links).
FRONTEND_URL=http://localhost:9002
# Email (password reset). Leave EMAIL_HOST empty to print emails to the console.
# For real delivery, set these (e.g. Gmail/SendGrid SMTP):
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Profinder <noreply@profinder.app>
# Require email verification before login. Defaults to ON automatically when
# EMAIL_HOST is set (so fake emails can't sign up). Set to False to disable.
# REQUIRE_EMAIL_VERIFICATION=True
# Google Sign-In (optional). OAuth 2.0 Web Client ID; leave empty to disable.
# Must match the frontend's NEXT_PUBLIC_GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=
