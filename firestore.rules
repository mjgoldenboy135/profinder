
rules_version = '2';

service cloud.firestore {
  match /databases/profind/documents {

    // Users Collection
    // - Anyone can read public profiles (if not explicitly restricted by app logic).
    // - Only the authenticated user can create their own profile.
    // - Only the authenticated user can update their own profile.
    // - Deletion of user profiles is typically handled by backend functions or restricted.
    match /users/{userId} {
      allow read: if true; // Allows public reading of profiles. Change to `request.auth != null;` to restrict to logged-in users.
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false; // Typically, users don't delete their own accounts directly; admins or backend processes might.
    }

    // Chats Collection
    // - Users can only read chats they are participants in.
    // - Users can create chats if they are authenticated and one of the participants.
    // - Users can update chats (e.g., last message) if they are participants.
    // - Users can delete chats they are participants in.
    match /chats/{chatId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.participantIds;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participantIds;
      allow update: if request.auth != null && request.auth.uid in resource.data.participantIds;
      allow delete: if request.auth != null && request.auth.uid in resource.data.participantIds; // Allows participants to delete chats

      // Messages Subcollection within Chats
      // - Users can read messages in chats they are participants in.
      // - Users can create messages in chats they are participants in, and they are the sender.
      // - Updating/deleting messages is generally restricted or handled carefully.
      match /messages/{messageId} {
        allow read: if request.auth != null && get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds.hasAny([request.auth.uid]);
        allow create: if request.auth != null && get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds.hasAny([request.auth.uid]) && request.resource.data.senderId == request.auth.uid;
        allow update: if false; // Typically, disallow direct message updates by users.
        allow delete: if false; // Typically, disallow direct message deletions by users.
      }
    }
  }
}
