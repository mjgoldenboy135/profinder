
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users Collection
    match /users/{userId} {
      // Any authenticated user can read public user profiles. This is needed for the user list and map.
      allow read: if request.auth != null;
      
      // A user can only create their OWN document.
      allow create: if request.auth.uid == userId;
      
      // A user can only update their OWN document.
      allow update: if request.auth.uid == userId;
      
      // Users cannot delete their profiles through the app.
      allow delete: if false;
    }

    // Chats Collection
    match /chats/{chatId} {
      // A user can only interact with a chat if they are a participant.
      allow read, update, delete: if request.auth.uid in resource.data.participantIds;
      
      // A user can only create a chat if they are listed as one of the participants.
      allow create: if request.auth.uid in request.resource.data.participantIds;

      // Messages Subcollection
      match /messages/{messageId} {
        // A user can read messages in a chat they are part of.
        // We verify this by checking the parent chat document.
        allow read: if get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds[0] == request.auth.uid || 
                     get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds[1] == request.auth.uid;

        // A user can create (send) messages in a chat they are part of.
        allow create: if get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds[0] == request.auth.uid || 
                       get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds[1] == request.auth.uid;
        
        // Users cannot update messages.
        allow update: if false;
        
        // A user can delete messages in a chat they are part of (e.g., if you add this feature later).
        allow delete: if get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds[0] == request.auth.uid || 
                       get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds[1] == request.auth.uid;
      }
    }
  }
}
