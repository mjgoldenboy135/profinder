
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users Collection
    // - Anyone can read user profiles (public profiles).
    // - Only the authenticated owner can create or update their own profile.
    // - Deletion is disallowed through client SDKs for safety.
    match /users/{userId} {
      allow read: if true; // Publicly readable
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false; // Or set to `if request.auth != null && request.auth.uid == userId;` if needed
    }

    // Chats Collection
    // - Users can only access chats they are participants in.
    // - Creating a chat requires authentication.
    // - Updating a chat (e.g., last message) requires authentication and participation.
    match /chats/{chatId} {
      allow get: if request.auth != null && request.auth.uid in resource.data.participantIds;
      // For listing/querying chats:
      // This rule allows an authenticated user to query the chats collection.
      // The actual filtering (e.g., `where('participantIds', 'array-contains', userId)`)
      // is done in the client-side query. This ensures that even if a broader list
      // is requested, the security rules for individual document reads (`get`)
      // would still apply if not for this specific list rule.
      allow list: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participantIds;
      allow update: if request.auth != null && request.auth.uid in resource.data.participantIds;
      allow delete: if request.auth != null && request.auth.uid in resource.data.participantIds; // Allow participants to delete

      // Messages Subcollection within Chats
      // - Users can only read/write messages in chats they participate in.
      match /messages/{messageId} {
        allow read: if request.auth != null && get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds.hasAny([request.auth.uid]);
        allow create: if request.auth != null && request.auth.uid == request.resource.data.senderId && get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds.hasAny([request.auth.uid]);
        // No updates or deletes for messages by default to maintain chat history integrity
        allow update: if false;
        allow delete: if false;
      }
    }
  }
}
